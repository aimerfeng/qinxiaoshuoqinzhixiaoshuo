# ===========================================
# Project Anima Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
#
# For local development with Docker:
#   1. Copy this file: cp .env.example .env
#   2. Start Docker services: docker-compose up -d
#   3. Run database migrations: npm run db:migrate
#   4. Start the backend: npm run start:dev

# Application
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:3000

# ===========================================
# Database (PostgreSQL)
# ===========================================
# For local development with Docker (recommended):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/project_anima?schema=public
#
# For Prisma Postgres (cloud development):
# DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=your_api_key
#
# For production (use managed PostgreSQL):
# DATABASE_URL=postgresql://user:password@host:5432/database?schema=public&sslmode=require

# Database Connection Pool Configuration
# 连接池配置（根据服务器资源调整）
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=5000
DB_POOL_DEBUG=false

# ===========================================
# Redis
# ===========================================
# For local development with Docker:
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379
#
# For production (use managed Redis):
# REDIS_HOST=your-redis-host.cache.amazonaws.com
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
# REDIS_URL=redis://:password@host:6379

# ===========================================
# S3 Compatible Storage
# ===========================================
# For local development with MinIO (Docker):
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=project-anima
S3_FORCE_PATH_STYLE=true
#
# For production (AWS S3 or compatible):
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_REGION=ap-northeast-1
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET=your-bucket-name
# S3_FORCE_PATH_STYLE=false
#
# For Volcano Cloud TOS (S3 compatible):
# S3_ENDPOINT=https://tos-s3-cn-beijing.volces.com
# S3_REGION=cn-beijing

# ===========================================
# JWT Authentication
# ===========================================
# IMPORTANT: Change this in production!
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# ===========================================
# Email Service (optional for development)
# ===========================================
# For development, emails are logged to console
# For production, configure SMTP:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password
# SMTP_FROM=noreply@projectanima.com

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=debug
LOG_FORMAT=pretty
# For production:
# LOG_LEVEL=info
# LOG_FORMAT=json

# Request/Response body logging (development only)
LOG_REQUEST_BODY=false
LOG_RESPONSE_BODY=false
