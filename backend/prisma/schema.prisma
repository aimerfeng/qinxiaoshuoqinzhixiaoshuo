// This is your Prisma schema file for Project Anima
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [uuid_ossp(map: "uuid-ossp"), vector]
}

// ==================== User & Authentication ====================

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  username        String    @unique
  passwordHash    String    @map("password_hash")
  displayName     String?   @map("display_name")
  avatar          String?
  bio             String?
  isEmailVerified Boolean   @default(false) @map("is_email_verified")
  isActive        Boolean   @default(true) @map("is_active")
  isAdmin         Boolean   @default(false) @map("is_admin") // 管理员标记
  lastLoginAt     DateTime? @map("last_login_at")
  loginAttempts   Int       @default(0) @map("login_attempts")
  lockedUntil     DateTime? @map("locked_until")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // 会员等级相关字段
  memberLevel       MemberLevel @default(REGULAR) @map("member_level")
  contributionScore Int         @default(0) @map("contribution_score")

  // 阅读统计字段
  totalReadingMinutes Int @default(0) @map("total_reading_minutes") // 累计阅读时长（分钟）

  // 连续阅读统计字段 (需求24.3.3)
  lastReadDate         DateTime? @map("last_read_date") // 最后阅读日期
  currentReadingStreak Int       @default(0) @map("current_reading_streak") // 当前连续阅读天数
  longestReadingStreak Int       @default(0) @map("longest_reading_streak") // 最长连续阅读天数

  // 连续更新统计字段 (需求24.4.5)
  lastUpdateDate      DateTime? @map("last_update_date") // 最后更新日期（发布章节）
  currentUpdateStreak Int       @default(0) @map("current_update_streak") // 当前连续更新天数
  longestUpdateStreak Int       @default(0) @map("longest_update_streak") // 最长连续更新天数

  // Relations
  profile                UserProfile?
  followers              Follow[]                @relation("UserFollowing") // 关注我的人
  following              Follow[]                @relation("UserFollowers") // 我关注的人
  refreshTokens          RefreshToken[]
  works                  Work[]
  chapters               Chapter[]
  cards                  Card[]
  comments               Comment[]
  likes                  Like[]
  readingProgress        ReadingProgress[]
  readingSettings        ReadingSettings?
  workCompletions        WorkCompletion[]
  notifications          Notification[]
  deviceFingerprints     DeviceFingerprint[]
  danmakus               Danmaku[]
  readingList            ReadingListItem[]
  contributionRecords    ContributionRecord[]
  memberApplications     MemberApplication[]
  wallet                 Wallet?
  createdActivities      Activity[]              @relation("ActivityCreator")
  activityParticipations ActivityParticipation[]
  activityRewards        ActivityReward[]

  // 私信系统关系
  conversations ConversationParticipant[]
  sentMessages  Message[]                 @relation("SentMessages")

  // 黑名单系统关系
  blockedUsers   UserBlacklist[] @relation("UserBlocking") // 我拉黑的人
  blockedByUsers UserBlacklist[] @relation("UserBlockedBy") // 拉黑我的人

  // 用户设置关系
  settings UserSettings?

  // 类型探索关系 (需求24.3.5)
  genresRead UserGenreRead[]

  // 登录连续天数关系 (需求24.6.2)
  loginStreak UserLoginStreak?

  // 赛季排行榜系统关系 (需求25)
  seasonRanks        SeasonRank[]
  seasonLeaderboards SeasonLeaderboard[]

  // 小说库分支系统关系
  libraries          Library[]
  branches           LibraryBranch[]
  suggestions        ContentSuggestion[]
  branchTransactions BranchTransaction[]

  @@index([memberLevel])
  @@map("users")
}

model UserProfile {
  id              String    @id @default(uuid())
  userId          String    @unique @map("user_id")
  backgroundImage String?   @map("background_image")
  website         String?
  location        String?
  birthday        DateTime?
  gender          Gender?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model RefreshToken {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  token      String   @unique
  deviceInfo String?  @map("device_info")
  ipAddress  String?  @map("ip_address")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model DeviceFingerprint {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  fingerprint String
  userAgent   String?  @map("user_agent")
  ipAddress   String?  @map("ip_address")
  deviceInfo  Json?    @map("device_info")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")
  createdAt   DateTime @default(now()) @map("created_at")

  // 需求21: 登录设备管理 - 额外字段
  deviceName String? @map("device_name") // 设备名称（如 "Chrome on Windows"）
  deviceType String? @map("device_type") // 设备类型（desktop/mobile/tablet）
  browser    String? // 浏览器名称
  os         String? // 操作系统
  location   String? // 地理位置（基于IP）

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@index([fingerprint])
  @@index([ipAddress])
  @@index([userId])
  @@map("device_fingerprints")
}

// ==================== Works & Chapters ====================

model Work {
  id          String      @id @default(uuid())
  authorId    String      @map("author_id")
  uploaderId  String?     @map("uploader_id") // 上传者ID（用于区分上传者和原作者）
  title       String
  description String?
  coverImage  String?     @map("cover_image")
  status      WorkStatus  @default(DRAFT)
  contentType ContentType @default(NOVEL)
  wordCount   Int         @default(0) @map("word_count")
  viewCount   Int         @default(0) @map("view_count")
  likeCount   Int         @default(0) @map("like_count")
  quoteCount  Int         @default(0) @map("quote_count")
  isDeleted   Boolean     @default(false) @map("is_deleted")
  publishedAt DateTime?   @map("published_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Manga-specific fields (漫画特有字段)
  readingDirection ReadingDirection? @map("reading_direction") // 阅读方向：LTR(从左到右)/RTL(从右到左，日漫)
  pageCount        Int               @default(0) @map("page_count") // 总页数（漫画用）

  // Relations
  author           User              @relation(fields: [authorId], references: [id])
  chapters         Chapter[]
  tags             WorkTag[]
  readingListItems ReadingListItem[]
  completions      WorkCompletion[]
  library          Library? // 作为小说库的原始作品
  branch           LibraryBranch? // 作为分支的内容载体

  @@index([authorId])
  @@index([uploaderId])
  @@index([status])
  @@index([contentType])
  @@map("works")
}

model Chapter {
  id          String        @id @default(uuid())
  workId      String        @map("work_id")
  authorId    String        @map("author_id")
  title       String
  content     String
  orderIndex  Int           @map("order_index")
  wordCount   Int           @default(0) @map("word_count")
  viewCount   Int           @default(0) @map("view_count")
  status      ChapterStatus @default(DRAFT)
  version     Int           @default(1)
  publishedAt DateTime?     @map("published_at")
  scheduledAt DateTime?     @map("scheduled_at")
  isDeleted   Boolean       @default(false) @map("is_deleted")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  work            Work              @relation(fields: [workId], references: [id], onDelete: Cascade)
  author          User              @relation(fields: [authorId], references: [id])
  paragraphs      Paragraph[]
  versions        ChapterVersion[]
  readingProgress ReadingProgress[]
  mangaPages      MangaPage[]
  forkBranches    LibraryBranch[]   @relation("ForkFromChapter")

  @@unique([workId, orderIndex])
  @@index([workId])
  @@index([scheduledAt])
  @@map("chapters")
}

model ChapterVersion {
  id        String   @id @default(uuid())
  chapterId String   @map("chapter_id")
  version   Int
  title     String
  content   String
  wordCount Int      @map("word_count")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, version])
  @@map("chapter_versions")
}

// ==================== Manga Pages ====================

model MangaPage {
  id           String   @id @default(uuid())
  chapterId    String   @map("chapter_id")
  imageUrl     String   @map("image_url")
  thumbnailUrl String?  @map("thumbnail_url")
  orderIndex   Int      @map("order_index")
  width        Int? // 图片宽度（像素）
  height       Int? // 图片高度（像素）
  fileSize     Int?     @map("file_size") // 文件大小（字节）
  isDeleted    Boolean  @default(false) @map("is_deleted")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, orderIndex])
  @@index([chapterId])
  @@map("manga_pages")
}

// ==================== Paragraphs & Anchors ====================

model Paragraph {
  id          String   @id @default(uuid())
  chapterId   String   @map("chapter_id")
  anchorId    String   @unique @map("anchor_id") // Format: {work_id}:{chapter_id}:{paragraph_index}
  content     String
  contentHash String   @map("content_hash")
  orderIndex  Int      @map("order_index")
  quoteCount  Int      @default(0) @map("quote_count")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  chapter      Chapter             @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  quotes       Quote[]
  forkBranches LibraryBranch[]     @relation("ForkFromParagraph")
  suggestions  ContentSuggestion[]

  @@unique([chapterId, orderIndex])
  @@index([anchorId])
  @@map("paragraphs")
}

// ==================== Plaza & Social ====================

model Card {
  id           String   @id @default(uuid())
  authorId     String   @map("author_id")
  content      String
  likeCount    Int      @default(0) @map("like_count")
  commentCount Int      @default(0) @map("comment_count")
  quoteCount   Int      @default(0) @map("quote_count")
  hotScore     Float    @default(0) @map("hot_score")
  isDeleted    Boolean  @default(false) @map("is_deleted")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  author     User               @relation(fields: [authorId], references: [id])
  quotes     Quote[]
  comments   Comment[]
  likes      Like[]
  suggestion ContentSuggestion?

  @@index([authorId])
  @@index([hotScore])
  @@index([createdAt])
  @@map("cards")
}

model Quote {
  id              String   @id @default(uuid())
  cardId          String   @map("card_id")
  paragraphId     String   @map("paragraph_id")
  originalContent String   @map("original_content") // Snapshot of content at quote time
  contentUpdated  Boolean  @default(false) @map("content_updated")
  contentDeleted  Boolean  @default(false) @map("content_deleted")
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  card      Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)
  paragraph Paragraph @relation(fields: [paragraphId], references: [id])

  @@map("quotes")
}

model Comment {
  id        String   @id @default(uuid())
  cardId    String   @map("card_id")
  authorId  String   @map("author_id")
  parentId  String?  @map("parent_id")
  content   String
  likeCount Int      @default(0) @map("like_count")
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  card    Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id])
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@index([cardId])
  @@map("comments")
}

model Like {
  id         String         @id @default(uuid())
  userId     String         @map("user_id")
  cardId     String?        @map("card_id")
  targetType LikeTargetType @map("target_type")
  targetId   String         @map("target_id")
  createdAt  DateTime       @default(now()) @map("created_at")

  // Relations
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card? @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@map("likes")
}

// ==================== Reading ====================

model ReadingProgress {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  chapterId      String   @map("chapter_id")
  paragraphIndex Int      @map("paragraph_index")
  scrollPosition Float?   @map("scroll_position")
  readPercentage Float    @default(0) @map("read_percentage")
  lastReadAt     DateTime @default(now()) @map("last_read_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@map("reading_progress")
}

model ReadingSettings {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  fontSize        Int      @default(16) @map("font_size")
  lineHeight      Float    @default(1.8) @map("line_height")
  fontFamily      String   @default("system") @map("font_family")
  backgroundColor String   @default("#ffffff") @map("background_color")
  textColor       String   @default("#1f2937") @map("text_color")
  pageMode        PageMode @default(SCROLL) @map("page_mode")
  nightMode       Boolean  @default(false) @map("night_mode")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reading_settings")
}

// 作品完成记录模型 - 记录用户完成阅读的作品
// 需求24.3.4: 完本成就（初尝完结→完本狂魔）
model WorkCompletion {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  workId      String   @map("work_id")
  completedAt DateTime @default(now()) @map("completed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([userId, workId])
  @@index([userId])
  @@index([workId])
  @@map("work_completions")
}

// 用户类型阅读记录模型 - 记录用户阅读过的作品类型/标签
// 需求24.3.5: 类型探索成就（类型新手→全类型通）
model UserGenreRead {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  tagId       String   @map("tag_id")
  firstReadAt DateTime @default(now()) @map("first_read_at")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([userId, tagId])
  @@index([userId])
  @@index([tagId])
  @@map("user_genre_reads")
}

// 需求24.6.2: 隐藏成就（全勤王）- 用户登录连续天数记录
model UserLoginStreak {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  currentStreak Int      @default(0) @map("current_streak") // 当前连续登录天数
  longestStreak Int      @default(0) @map("longest_streak") // 历史最长连续登录天数
  lastLoginDate DateTime @map("last_login_date") // 最后登录日期
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lastLoginDate])
  @@map("user_login_streaks")
}

// ==================== Tags ====================

model Tag {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  usageCount  Int      @default(0) @map("usage_count")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  works     WorkTag[]
  userReads UserGenreRead[]

  @@map("tags")
}

model WorkTag {
  workId    String   @map("work_id")
  tagId     String   @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([workId, tagId])
  @@map("work_tags")
}

// ==================== Notifications ====================

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  content   String
  data      Json?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ==================== Vector Embeddings (pgvector) ====================
// Used for semantic search and AI-powered recommendations (Phase 3)

model ContentEmbedding {
  id          String                      @id @default(uuid())
  contentType ContentEmbeddingType        @map("content_type")
  contentId   String                      @map("content_id")
  embedding   Unsupported("vector(768)")? // 768 dimensions for BERT-based models
  textPreview String?                     @map("text_preview")
  metadata    Json?
  createdAt   DateTime                    @default(now()) @map("created_at")
  updatedAt   DateTime                    @updatedAt @map("updated_at")

  @@unique([contentType, contentId])
  @@index([contentType])
  @@map("content_embeddings")
}

model UserInterestEmbedding {
  id           String                      @id @default(uuid())
  userId       String                      @map("user_id")
  interestType UserInterestType            @map("interest_type")
  embedding    Unsupported("vector(768)")? // 768 dimensions
  weight       Float                       @default(1.0)
  updatedAt    DateTime                    @updatedAt @map("updated_at")

  @@unique([userId, interestType])
  @@map("user_interest_embeddings")
}

// ==================== Enums ====================

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum WorkStatus {
  DRAFT
  PUBLISHED
  COMPLETED
  HIATUS
  ABANDONED
}

enum ContentType {
  NOVEL
  MANGA
}

enum ReadingDirection {
  LTR // Left to Right (西方漫画、韩漫)
  RTL // Right to Left (日漫)
}

enum ChapterStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

enum PageMode {
  SCROLL
  PAGINATED
}

enum LikeTargetType {
  CARD
  COMMENT
}

enum NotificationType {
  SYSTEM
  LIKE
  COMMENT
  FOLLOW
  CHAPTER_UPDATE
  QUOTE
  MENTION
}

enum ContentEmbeddingType {
  WORK
  CHAPTER
  PARAGRAPH
  CARD
}

enum UserInterestType {
  SHORT_TERM
  LONG_TERM
  EXPLICIT
}

// ==================== Danmaku (弹幕系统) ====================

model Danmaku {
  id        String      @id @default(uuid())
  anchorId  String      @map("anchor_id") // 绑定到段落的 Anchor_ID
  authorId  String      @map("author_id")
  content   String      @db.VarChar(100) // 弹幕限制100字
  color     String      @default("#FFFFFF")
  type      DanmakuType @default(SCROLL) // SCROLL / TOP / BOTTOM
  fontSize  Int         @default(24) @map("font_size")
  likeCount Int         @default(0) @map("like_count")
  isDeleted Boolean     @default(false) @map("is_deleted")
  createdAt DateTime    @default(now()) @map("created_at")

  // Relations
  author User @relation(fields: [authorId], references: [id])

  @@index([anchorId])
  @@index([authorId])
  @@map("danmaku")
}

enum DanmakuType {
  SCROLL // 滚动弹幕
  TOP // 顶部固定
  BOTTOM // 底部固定
}

// ==================== Search History ====================

model SearchHistory {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id")
  query       String
  resultCount Int      @default(0) @map("result_count")
  searchType  String   @default("all") @map("search_type") // all, work, user, chapter
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([query])
  @@index([createdAt(sort: Desc)])
  @@map("search_history")
}

// ==================== Draft (草稿系统) ====================

model Draft {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  title          String? // 草稿标题
  content        String   @db.Text // Markdown 内容
  workId         String?  @map("work_id") // 关联的作品ID（可选，用于已有作品）
  chapterId      String?  @map("chapter_id") // 关联的章节ID（可选，用于已有章节）
  cursorPosition Int?     @map("cursor_position") // 光标位置
  wordCount      Int      @default(0) @map("word_count") // 字数统计
  isDeleted      Boolean  @default(false) @map("is_deleted")
  lastSavedAt    DateTime @default(now()) @map("last_saved_at") // 最后保存时间
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([userId, workId, chapterId]) // 每个用户对每个作品/章节只有一个草稿
  @@index([userId])
  @@index([workId])
  @@index([chapterId])
  @@map("drafts")
}

// ==================== Reading List (阅读列表) ====================

model ReadingListItem {
  id                String            @id @default(uuid())
  userId            String            @map("user_id")
  workId            String            @map("work_id")
  status            ReadingListStatus @default(WANT_TO_READ)
  lastReadChapterId String?           @map("last_read_chapter_id")
  lastReadAt        DateTime?         @map("last_read_at")
  hasUpdate         Boolean           @default(false) @map("has_update") // 是否有新章节更新
  note              String? // 用户备注
  rating            Int? // 用户评分 1-5
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([userId, workId])
  @@index([userId, status])
  @@index([userId, hasUpdate])
  @@index([lastReadAt])
  @@map("reading_list_items")
}

enum ReadingListStatus {
  WANT_TO_READ // 想读
  READING // 在读
  COMPLETED // 已读完
  DROPPED // 弃坑
  ON_HOLD // 暂停
}

// ==================== 会员等级体系 (Membership System) ====================

// 会员等级枚举
enum MemberLevel {
  REGULAR // Lv.0 普通会员 - 注册即得
  OFFICIAL // Lv.1 正式会员 - 贡献度达标+审核通过
  SENIOR // Lv.2 资深会员 - 持续贡献+时间沉淀
  HONORARY // Lv.3 荣誉会员 - 特殊贡献+官方认证
}

// 贡献类型枚举
enum ContributionType {
  // 阅读贡献
  READ_CHAPTER // 完整阅读1章节 +2
  READ_DURATION // 累计阅读30分钟 +5

  // 互动贡献
  COMMENT_VALID // 发布有效评论（≥20字） +3
  COMMENT_LIKED // 评论被点赞 +1
  QUOTE_INTERACTED // 引用被互动（点赞/评论） +2

  // 创作贡献
  PUBLISH_CHAPTER // 发布章节 +20
  WORK_FAVORITED // 作品被收藏 +5
  PARAGRAPH_QUOTED // 段落被引用 +3

  // 社区贡献
  REPORT_VALID // 举报有效违规 +10
  ACTIVITY_PARTICIPATE // 参与官方活动 +15

  // 建议贡献
  SUGGESTION_ACCEPTED // 修订建议被采纳 +可配置
}

// 贡献度记录模型
model ContributionRecord {
  id            String           @id @default(uuid())
  userId        String           @map("user_id")
  type          ContributionType
  points        Int // 获得的积分
  referenceId   String?          @map("reference_id") // 关联的实体ID（章节ID、评论ID等）
  referenceType String?          @map("reference_type") // 关联实体类型
  description   String? // 描述信息
  createdAt     DateTime         @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("contribution_records")
}

// 会员申请状态枚举
enum MemberApplicationStatus {
  PENDING // 待审核
  APPROVED // 已通过
  REJECTED // 已拒绝
}

// 会员申请模型
model MemberApplication {
  id           String                  @id @default(uuid())
  userId       String                  @map("user_id")
  targetLevel  MemberLevel             @map("target_level") // 申请的目标等级
  currentScore Int                     @map("current_score") // 申请时的贡献度
  status       MemberApplicationStatus @default(PENDING)
  reason       String? // 申请理由
  rejectReason String?                 @map("reject_reason") // 拒绝原因
  reviewerId   String?                 @map("reviewer_id") // 审核人ID
  reviewedAt   DateTime?               @map("reviewed_at") // 审核时间
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("member_applications")
}

// ==================== 社区活动系统 (Community Activity System) ====================

// 活动类型枚举
enum ActivityType {
  READING_CHALLENGE // 阅读打卡
  WRITING_CONTEST // 评论征集/创作接力
  COMMUNITY_EVENT // 社区活动（引用挑战等）
  SPECIAL_EVENT // 官方特殊活动
}

// 活动状态枚举
enum ActivityStatus {
  DRAFT // 草稿
  PENDING // 待审核
  ACTIVE // 进行中
  ENDED // 已结束
  CANCELLED // 已取消
}

// 参与状态枚举
enum ParticipationStatus {
  JOINED // 已参与
  COMPLETED // 已完成
  FAILED // 未完成
  WITHDRAWN // 已退出
}

// 奖励类型枚举
enum RewardType {
  MUSTARD_SEED // 零芥子代币
  BADGE // 徽章
  TITLE // 称号
  EXPERIENCE // 经验值
}

// 活动模型
model Activity {
  id              String         @id @default(uuid())
  title           String         @db.VarChar(30) // 活动名称 4-30字符
  description     String         @db.VarChar(500) // 活动描述 10-500字符
  coverImage      String?        @map("cover_image") // 活动封面图
  type            ActivityType // 活动类型
  status          ActivityStatus @default(DRAFT) // 活动状态
  startTime       DateTime       @map("start_time") // 开始时间
  endTime         DateTime       @map("end_time") // 结束时间
  rules           Json? // 活动规则和要求（JSON格式）
  rewards         Json? // 奖励配置（JSON格式）
  maxParticipants Int?           @map("max_participants") // 最大参与人数（可选）
  rewardPerPerson Int            @default(0) @map("reward_per_person") // 单人奖励金额
  totalPool       Int            @default(0) @map("total_pool") // 总奖池金额
  lockedPool      Int            @default(0) @map("locked_pool") // 已锁定的奖池金额
  creatorId       String         @map("creator_id") // 创建者ID
  reviewerId      String?        @map("reviewer_id") // 审核人ID
  reviewedAt      DateTime?      @map("reviewed_at") // 审核时间
  rejectReason    String?        @map("reject_reason") // 拒绝原因
  isDeleted       Boolean        @default(false) @map("is_deleted")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Relations
  creator         User                    @relation("ActivityCreator", fields: [creatorId], references: [id])
  participations  ActivityParticipation[]
  activityRewards ActivityReward[]

  @@index([creatorId])
  @@index([status])
  @@index([type])
  @@index([startTime])
  @@index([endTime])
  @@map("activities")
}

// 活动参与模型
model ActivityParticipation {
  id            String              @id @default(uuid())
  activityId    String              @map("activity_id")
  userId        String              @map("user_id")
  status        ParticipationStatus @default(JOINED) // 参与状态
  progress      Json? // 进度数据（JSON格式）
  completedAt   DateTime?           @map("completed_at") // 完成时间
  rewardClaimed Boolean             @default(false) @map("reward_claimed") // 是否已领取奖励
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  // Relations
  activity Activity         @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewards  ActivityReward[]

  @@unique([activityId, userId]) // 每个用户只能参与一次同一活动
  @@index([activityId])
  @@index([userId])
  @@index([status])
  @@map("activity_participations")
}

// 活动奖励模型
model ActivityReward {
  id              String     @id @default(uuid())
  activityId      String     @map("activity_id")
  userId          String     @map("user_id")
  participationId String     @map("participation_id")
  rewardType      RewardType @map("reward_type") // 奖励类型
  amount          Int        @default(0) // 数量（零芥子/经验值）
  badgeId         String?    @map("badge_id") // 徽章ID（可选）
  titleId         String?    @map("title_id") // 称号ID（可选）
  claimedAt       DateTime   @default(now()) @map("claimed_at") // 领取时间
  createdAt       DateTime   @default(now()) @map("created_at")

  // Relations
  activity      Activity              @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  participation ActivityParticipation @relation(fields: [participationId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@index([userId])
  @@index([participationId])
  @@index([rewardType])
  @@map("activity_rewards")
}

// ==================== 零芥子代币系统 (Mustard Seed Token System) ====================

// 交易类型枚举
enum TransactionType {
  DAILY_CLAIM // 每日领取
  TIP_SENT // 打赏发出
  TIP_RECEIVED // 打赏收到
  REWARD // 活动奖励
  REFUND // 退款
}

// 钱包模型 - 存储用户的零芥子余额
model Wallet {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  balance       Int      @default(0) // 当前余额
  totalReceived Int      @default(0) @map("total_received") // 累计收到
  totalSent     Int      @default(0) @map("total_sent") // 累计发出
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("wallets")
}

// 交易记录模型 - 记录所有零芥子交易
model Transaction {
  id            String          @id @default(uuid())
  walletId      String          @map("wallet_id")
  type          TransactionType
  amount        Int // 交易金额（正数表示收入，负数表示支出）
  referenceId   String?         @map("reference_id") // 关联ID（作品/章节/用户/活动ID）
  referenceType String?         @map("reference_type") // 关联类型（work/chapter/user/activity）
  description   String? // 交易描述
  createdAt     DateTime        @default(now()) @map("created_at")

  // Relations
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
  @@index([referenceId, referenceType])
  @@map("transactions")
}

// 每日领取记录模型 - 防止同一天多次领取
model DailyClaimRecord {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  claimDate DateTime @map("claim_date") @db.Date // 领取日期（只存日期部分）
  amount    Int // 领取金额
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, claimDate]) // 每个用户每天只能领取一次
  @@index([userId])
  @@index([claimDate])
  @@map("daily_claim_records")
}

// 打赏记录模型 - 详细的打赏记录
model TipRecord {
  id         String   @id @default(uuid())
  fromUserId String   @map("from_user_id") // 打赏者
  toUserId   String   @map("to_user_id") // 被打赏者
  workId     String?  @map("work_id") // 关联作品（可选）
  chapterId  String?  @map("chapter_id") // 关联章节（可选）
  amount     Int // 打赏金额
  message    String? // 打赏留言
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([fromUserId])
  @@index([toUserId])
  @@index([workId])
  @@index([chapterId])
  @@index([createdAt])
  @@map("tip_records")
}

// ==================== 内容举报系统 (Content Report System) ====================

// 举报状态枚举
enum ReportStatus {
  PENDING // 待审核
  REVIEWING // 审核中（已领取）
  APPROVED // 已通过（违规确认）
  REJECTED // 已拒绝（举报无效）
  ARCHIVED // 已归档
}

// 举报目标类型枚举
enum ReportTargetType {
  WORK // 作品
  CHAPTER // 章节
  CARD // 广场卡片
  COMMENT // 评论
  DANMAKU // 弹幕
  USER // 用户
}

// 举报原因枚举
enum ReportReason {
  SPAM // 垃圾内容
  HARASSMENT // 骚扰
  INAPPROPRIATE // 不当内容
  COPYRIGHT // 侵权
  MISINFORMATION // 虚假信息
  VIOLENCE // 暴力内容
  HATE_SPEECH // 仇恨言论
  OTHER // 其他
}

// 审核处理动作枚举
enum ModerationAction {
  DELETE_CONTENT // 删除内容
  WARN_USER // 警告用户
  BAN_USER // 封禁用户
  DISMISS // 驳回举报
}

// 内容举报模型
model ContentReport {
  id          String            @id @default(uuid())
  reporterId  String            @map("reporter_id") // 举报者ID
  targetType  ReportTargetType  @map("target_type") // 举报目标类型
  targetId    String            @map("target_id") // 举报目标ID
  reason      ReportReason // 举报原因
  description String?           @db.VarChar(500) // 详细描述
  evidence    String[]          @default([]) // 证据（截图URL等）
  status      ReportStatus      @default(PENDING) // 举报状态
  reviewerId  String?           @map("reviewer_id") // 审核员ID
  reviewNote  String?           @map("review_note") // 审核备注
  action      ModerationAction? // 处理动作
  reviewedAt  DateTime?         @map("reviewed_at") // 审核时间
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@index([reporterId])
  @@index([targetType, targetId])
  @@index([status])
  @@index([reviewerId])
  @@index([createdAt])
  @@map("content_reports")
}

// ==================== 关注系统 (Follow System) ====================

// 关注关系模型 - 用户之间的关注关系
model Follow {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id") // 关注者（发起关注的人）
  followingId String   @map("following_id") // 被关注者（被关注的人）
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  follower  User @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId]) // 每对用户只能有一条关注记录
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

// ==================== 风控告警系统 (Risk Alert System) ====================

// 告警类型枚举
enum RiskAlertType {
  MULTI_ACCOUNT_DETECTED // 同设备/IP多账户
  SUSPICIOUS_TRANSACTION // 可疑交易模式
  RATE_LIMIT_EXCEEDED // 频率限制违规
  CIRCULAR_TRANSFER // 循环转账检测
  CONCENTRATED_RECEIPTS // 新账户集中收币
  ACCOUNT_CLUSTER // 可疑账户集群
}

// 告警严重程度枚举
enum RiskAlertSeverity {
  CRITICAL // 需要立即处理
  HIGH // 需要在数小时内处理
  MEDIUM // 需要在数天内处理
  LOW // 信息性告警
}

// 告警状态枚举
enum RiskAlertStatus {
  PENDING // 待处理
  INVESTIGATING // 调查中
  RESOLVED // 已解决
  DISMISSED // 已忽略
}

// 风控告警模型
model RiskAlert {
  id              String            @id @default(uuid())
  type            RiskAlertType // 告警类型
  severity        RiskAlertSeverity // 严重程度
  status          RiskAlertStatus   @default(PENDING) // 告警状态
  title           String // 告警标题
  description     String? // 详细描述
  data            Json? // 告警相关数据
  affectedUserIds String[]          @default([]) @map("affected_user_ids") // 受影响的用户ID列表
  sourceService   String?           @map("source_service") // 触发告警的服务
  assignedTo      String?           @map("assigned_to") // 分配给的管理员ID
  resolvedAt      DateTime?         @map("resolved_at") // 解决时间
  resolvedBy      String?           @map("resolved_by") // 解决人ID
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  // Relations
  notes RiskAlertNote[]

  @@index([type])
  @@index([severity])
  @@index([status])
  @@index([assignedTo])
  @@index([createdAt])
  @@map("risk_alerts")
}

// 风控告警备注模型
model RiskAlertNote {
  id        String   @id @default(uuid())
  alertId   String   @map("alert_id")
  authorId  String   @map("author_id") // 备注作者ID
  content   String // 备注内容
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  alert RiskAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@index([alertId])
  @@index([authorId])
  @@map("risk_alert_notes")
}

// ==================== 惩罚执行系统 (Punishment Execution System) ====================

// 惩罚类型枚举
enum PunishmentType {
  WARNING // 警告（记录但不限制）
  MUTE // 禁言（限制发言、评论、弹幕）
  FEATURE_RESTRICT // 功能限制（限制特定功能如打赏、发布）
  ACCOUNT_FREEZE // 账户冻结（暂停账户活动）
  ACCOUNT_BAN // 账户封禁（永久封禁）
}

// 惩罚状态枚举
enum PunishmentStatus {
  ACTIVE // 生效中
  EXPIRED // 已过期
  REVOKED // 已撤销
}

// 用户惩罚模型
model UserPunishment {
  id           String           @id @default(uuid())
  userId       String           @map("user_id") // 被惩罚的用户ID
  type         PunishmentType // 惩罚类型
  status       PunishmentStatus @default(ACTIVE) // 惩罚状态
  reason       String // 惩罚原因
  description  String? // 详细描述
  alertId      String?          @map("alert_id") // 关联的风控告警ID
  isPermanent  Boolean          @default(false) @map("is_permanent") // 是否永久
  expiresAt    DateTime?        @map("expires_at") // 过期时间（临时惩罚）
  revokedAt    DateTime?        @map("revoked_at") // 撤销时间
  revokedBy    String?          @map("revoked_by") // 撤销人ID
  revokeReason String?          @map("revoke_reason") // 撤销原因
  createdBy    String           @map("created_by") // 创建人ID（管理员）
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@index([userId])
  @@index([userId, type])
  @@index([userId, status])
  @@index([type])
  @@index([status])
  @@index([alertId])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("user_punishments")
}

// ==================== 私信系统 (Private Messaging System) ====================

// 消息类型枚举
enum MessageType {
  TEXT // 文本消息
  IMAGE // 图片消息
  SYSTEM // 系统消息（如"用户加入"）
}

// 会话模型 - 代表用户之间的对话
model Conversation {
  id            String   @id @default(cuid())
  lastMessageAt DateTime @default(now()) @map("last_message_at") // 最后消息时间
  isGroup       Boolean  @default(false) @map("is_group") // 是否群聊（预留）
  title         String? // 群聊标题（可选）
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  participants ConversationParticipant[]
  messages     Message[]

  @@index([lastMessageAt(sort: Desc)])
  @@map("conversations")
}

// 会话参与者模型 - 会话与用户的关联表
model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String    @map("conversation_id")
  userId         String    @map("user_id")
  joinedAt       DateTime  @default(now()) @map("joined_at") // 加入时间
  lastReadAt     DateTime? @map("last_read_at") // 最后阅读时间（用于未读消息追踪）
  isAdmin        Boolean   @default(false) @map("is_admin") // 是否管理员（群聊用）
  isMuted        Boolean   @default(false) @map("is_muted") // 是否静音通知
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
  @@map("conversation_participants")
}

// 消息模型 - 单条消息
model Message {
  id             String      @id @default(cuid())
  conversationId String      @map("conversation_id")
  senderId       String      @map("sender_id")
  content        String // 消息内容
  messageType    MessageType @default(TEXT) @map("message_type") // 消息类型
  isDeleted      Boolean     @default(false) @map("is_deleted") // 是否已删除
  deletedAt      DateTime?   @map("deleted_at") // 删除时间
  replyToId      String?     @map("reply_to_id") // 回复的消息ID（自引用）
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  replyTo      Message?     @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[]    @relation("MessageReplies")

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([senderId])
  @@index([replyToId])
  @@map("messages")
}

// ==================== 用户设置系统 (User Settings System) ====================

// 个人资料可见性枚举
enum ProfileVisibility {
  PUBLIC // 公开
  FOLLOWERS_ONLY // 仅关注者可见
  PRIVATE // 仅自己可见
}

// 私信权限枚举
enum DirectMessagePermission {
  EVERYONE // 所有人
  FOLLOWERS_ONLY // 仅关注者
  NOBODY // 不接收
}

// 用户设置模型 - 存储用户的各项设置
model UserSettings {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")

  // 账户安全设置
  twoFactorEnabled         Boolean @default(false) @map("two_factor_enabled") // 两步验证
  loginNotificationEnabled Boolean @default(true) @map("login_notification_enabled") // 登录通知

  // 隐私设置
  profileVisibility   ProfileVisibility       @default(PUBLIC) @map("profile_visibility") // 主页可见性
  showOnlineStatus    Boolean                 @default(true) @map("show_online_status") // 显示在线状态
  allowDirectMessages DirectMessagePermission @default(EVERYONE) @map("allow_direct_messages") // 私信权限
  showReadingActivity Boolean                 @default(true) @map("show_reading_activity") // 显示阅读动态

  // 通知设置
  emailNotifications   Boolean @default(true) @map("email_notifications") // 邮件通知
  pushNotifications    Boolean @default(true) @map("push_notifications") // 推送通知
  commentNotifications Boolean @default(true) @map("comment_notifications") // 评论通知
  likeNotifications    Boolean @default(true) @map("like_notifications") // 点赞通知
  followNotifications  Boolean @default(true) @map("follow_notifications") // 关注通知
  mentionNotifications Boolean @default(true) @map("mention_notifications") // @提及通知
  updateNotifications  Boolean @default(true) @map("update_notifications") // 更新通知

  // 阅读设置
  defaultFontSize    Int     @default(16) @map("default_font_size") // 默认字体大小
  defaultLineHeight  Float   @default(1.8) @map("default_line_height") // 默认行高
  defaultTheme       String  @default("light") @map("default_theme") // 默认阅读主题
  autoNightMode      Boolean @default(false) @map("auto_night_mode") // 自动夜间模式
  nightModeStartTime String? @map("night_mode_start_time") // 夜间模式开始时间 (e.g., "22:00")
  nightModeEndTime   String? @map("night_mode_end_time") // 夜间模式结束时间 (e.g., "06:00")

  // 主题设置
  theme       String  @default("system") // 系统主题 (system/light/dark)
  accentColor String? @map("accent_color") // 自定义强调色

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ==================== 用户黑名单系统 (User Blacklist System) ====================

// 用户黑名单模型 - 用户之间的拉黑关系
model UserBlacklist {
  id            String   @id @default(cuid())
  userId        String   @map("user_id") // 拉黑者（发起拉黑的人）
  blockedUserId String   @map("blocked_user_id") // 被拉黑者
  reason        String? // 拉黑原因（可选）
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  user        User @relation("UserBlocking", fields: [userId], references: [id], onDelete: Cascade)
  blockedUser User @relation("UserBlockedBy", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, blockedUserId]) // 每对用户只能有一条拉黑记录
  @@index([userId])
  @@index([blockedUserId])
  @@map("user_blacklists")
}

// ==================== 新手引导系统 (Onboarding System) ====================

// 引导类型枚举
enum GuideType {
  REGISTRATION // 注册引导 - 完善资料、选择兴趣标签
  HOMEPAGE // 首页引导 - 介绍广场、推荐流、搜索入口
  READER // 阅读引导 - 介绍段落引用、阅读设置、章节导航
  CREATION // 创作引导 - 介绍编辑功能、发布流程、数据查看
}

// 引导进度模型
model OnboardingProgress {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  guideType   GuideType @map("guide_type")
  currentStep Int       @default(0) @map("current_step")
  totalSteps  Int       @map("total_steps")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([userId, guideType]) // 每个用户每种引导类型只有一条记录
  @@index([userId])
  @@index([guideType])
  @@map("onboarding_progress")
}

// ==================== 主题皮肤系统 (Theme System) ====================

// 主题解锁条件类型枚举
enum ThemeUnlockType {
  DEFAULT // 默认可用
  MEMBERSHIP // 会员等级解锁
  ACHIEVEMENT // 成就解锁
  PURCHASE // 购买解锁
  EVENT // 活动限定
  CREATOR // 创作者定制
}

// 主题模型 - 存储系统预设主题配置
model Theme {
  id           String  @id @default(uuid())
  name         String  @unique // 主题标识符（如 starry-fantasy, sakura-story）
  displayName  String  @map("display_name") // 显示名称（如 星空幻想、樱花物语）
  description  String? // 主题描述
  previewImage String? @map("preview_image") // 预览图URL

  // 颜色配置（JSON格式）
  // 包含: primary, primaryGradient, accentPink, accentGreen, bgPrimary, bgSecondary, bgCard, textPrimary, textSecondary, textMuted, border, shadowCard, shadowHover
  colors Json

  // 主题属性
  isDefault    Boolean @default(false) @map("is_default") // 是否默认主题
  isPremium    Boolean @default(false) @map("is_premium") // 是否高级主题
  isUnlockable Boolean @default(false) @map("is_unlockable") // 是否需要解锁

  // 解锁条件（JSON格式）
  // 包含: type (ThemeUnlockType), requirement (具体要求，如会员等级、成就ID、价格等)
  unlockCondition Json?           @map("unlock_condition")
  unlockType      ThemeUnlockType @default(DEFAULT) @map("unlock_type")

  // 排序和状态
  sortOrder Int     @default(0) @map("sort_order") // 排序顺序
  isActive  Boolean @default(true) @map("is_active") // 是否启用

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  userPreferences UserThemePreference[]

  @@index([name])
  @@index([isDefault])
  @@index([isPremium])
  @@index([unlockType])
  @@index([sortOrder])
  @@map("themes")
}

// 用户主题偏好模型 - 存储用户的主题选择和自定义配置
model UserThemePreference {
  id      String @id @default(uuid())
  userId  String @map("user_id")
  themeId String @map("theme_id")

  // 用户自定义覆盖（JSON格式）
  // 允许用户对主题进行微调，如自定义强调色等
  customizations Json?

  // 状态
  isActive   Boolean  @default(false) @map("is_active") // 是否当前激活的主题
  unlockedAt DateTime @default(now()) @map("unlocked_at") // 解锁时间

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  theme Theme @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@unique([userId, themeId]) // 每个用户对每个主题只有一条记录
  @@index([userId])
  @@index([themeId])
  @@index([userId, isActive])
  @@map("user_theme_preferences")
}

// ==================== 成就系统 (Achievement System) ====================

// 成就类别枚举
enum AchievementCategory {
  READING // 阅读成就（初窥门径→阅尽天下）
  CREATION // 创作成就（新人作者→千万传奇）
  SOCIAL // 社交成就（初有粉丝→互动之王）
  COLLECTION // 收藏成就
  SPECIAL // 特殊成就（元老用户/深夜书虫/彩蛋猎人）
  SEASONAL // 赛季成就
  EVENT // 活动成就
}

// 成就等级枚举
enum AchievementTier {
  BRONZE // 青铜
  SILVER // 白银
  GOLD // 黄金
  PLATINUM // 铂金
  DIAMOND // 钻石
  LEGENDARY // 传说
}

// 成就奖励类型枚举
enum AchievementRewardType {
  TOKENS // 零芥子代币
  BADGE // 徽章
  TITLE // 称号
  AVATAR_FRAME // 头像框
  THEME // 主题皮肤
}

// 成就定义模型 - 存储所有成就的定义
model Achievement {
  id          String              @id @default(uuid())
  name        String              @unique // 成就标识符（如 reading_beginner, creation_master）
  displayName String              @map("display_name") // 显示名称（如 初窥门径、创作大师）
  description String // 成就描述
  category    AchievementCategory // 成就类别
  tier        AchievementTier // 成就等级

  // 图标资源
  iconUrl  String? @map("icon_url") // 成就图标URL
  badgeUrl String? @map("badge_url") // 成就徽章URL

  // 达成条件
  targetValue Int @default(1) @map("target_value") // 目标值（如阅读100章节、发布10部作品）

  // 奖励配置
  rewardType  AchievementRewardType @map("reward_type") // 奖励类型
  rewardValue Json                  @map("reward_value") // 奖励详情（JSON格式：{amount: 100} 或 {badgeId: "xxx", title: "xxx"}）

  // 成就属性
  isHidden Boolean @default(false) @map("is_hidden") // 是否隐藏成就（问号占位）
  isActive Boolean @default(true) @map("is_active") // 是否启用

  // 排序
  sortOrder Int @default(0) @map("sort_order") // 排序顺序

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  userAchievements UserAchievement[]

  @@index([category])
  @@index([tier])
  @@index([isActive])
  @@index([isHidden])
  @@index([sortOrder])
  @@map("achievements")
}

// 用户成就进度模型 - 存储用户的成就进度和解锁状态
model UserAchievement {
  id            String @id @default(uuid())
  userId        String @map("user_id")
  achievementId String @map("achievement_id")

  // 进度追踪
  currentProgress Int       @default(0) @map("current_progress") // 当前进度
  isUnlocked      Boolean   @default(false) @map("is_unlocked") // 是否已解锁
  unlockedAt      DateTime? @map("unlocked_at") // 解锁时间

  // 奖励领取
  isClaimed Boolean   @default(false) @map("is_claimed") // 是否已领取奖励
  claimedAt DateTime? @map("claimed_at") // 领取时间

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId]) // 每个用户对每个成就只有一条记录
  @@index([userId])
  @@index([achievementId])
  @@index([userId, isUnlocked])
  @@index([userId, isClaimed])
  @@map("user_achievements")
}

// ==================== 赛季排行榜系统 (Season Ranking System) ====================

// 赛季状态枚举
enum SeasonStatus {
  UPCOMING // 即将开始
  ACTIVE // 进行中
  ENDED // 已结束
  SETTLED // 已结算（奖励已发放）
}

// 赛季段位枚举（从低到高）
enum SeasonTier {
  NOVICE // 新秀
  BRONZE // 青铜
  SILVER // 白银
  GOLD // 黄金
  PLATINUM // 铂金
  DIAMOND // 钻石
  MASTER // 大师
  GRANDMASTER // 宗师
  KING // 王者
}

// 排行榜类别枚举
enum LeaderboardCategory {
  READING // 阅读榜
  CREATION // 创作榜
  SOCIAL // 社交榜
  OVERALL // 综合榜
}

// 赛季模型 - 存储赛季基本信息
model Season {
  id           String       @id @default(uuid())
  name         String // 赛季名称（如 "第一赛季"、"2024春季赛"）
  description  String? // 赛季描述
  seasonNumber Int          @unique @map("season_number") // 赛季编号（1, 2, 3...）
  status       SeasonStatus @default(UPCOMING) // 赛季状态
  startDate    DateTime     @map("start_date") // 开始日期
  endDate      DateTime     @map("end_date") // 结束日期
  durationDays Int          @default(90) @map("duration_days") // 赛季时长（天）

  // 赛季配置（JSON格式）
  // 包含: 积分规则、段位阈值、奖励配置等
  config Json?

  // 软重置配置
  softResetEnabled Boolean @default(true) @map("soft_reset_enabled") // 是否启用软重置
  softResetRatio   Float   @default(0.5) @map("soft_reset_ratio") // 软重置比例（保留上赛季积分的比例）

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  ranks            SeasonRank[]
  leaderboards     SeasonLeaderboard[]
  rewards          SeasonReward[]
  userSeasonReward UserSeasonReward[]

  @@index([status])
  @@index([seasonNumber])
  @@index([startDate])
  @@index([endDate])
  @@map("seasons")
}

// 赛季段位模型 - 存储用户在赛季中的段位信息
model SeasonRank {
  id       String     @id @default(uuid())
  userId   String     @map("user_id")
  seasonId String     @map("season_id")
  tier     SeasonTier @default(NOVICE) // 当前段位
  points   Int        @default(0) // 赛季总积分

  // 段位变化追踪
  previousTier SeasonTier? @map("previous_tier") // 上赛季段位（用于软重置）
  peakTier     SeasonTier  @default(NOVICE) @map("peak_tier") // 本赛季最高段位
  peakPoints   Int         @default(0) @map("peak_points") // 本赛季最高积分

  // 积分明细（JSON格式）
  // 包含: readingPoints, creationPoints, socialPoints
  pointsBreakdown Json? @map("points_breakdown")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId]) // 每个用户每个赛季只有一条记录
  @@index([userId])
  @@index([seasonId])
  @@index([tier])
  @@index([points(sort: Desc)])
  @@index([seasonId, tier])
  @@index([seasonId, points(sort: Desc)])
  @@map("season_ranks")
}

// 赛季排行榜模型 - 存储各类别排行榜数据
model SeasonLeaderboard {
  id       String              @id @default(uuid())
  userId   String              @map("user_id")
  seasonId String              @map("season_id")
  category LeaderboardCategory // 排行榜类别

  score        Int  @default(0) // 该类别得分
  rank         Int? // 当前排名（可能为空，表示未上榜）
  previousRank Int? @map("previous_rank") // 上次排名（用于显示排名变化）

  // 排名变化追踪
  peakRank  Int? @map("peak_rank") // 本赛季最高排名
  peakScore Int  @default(0) @map("peak_score") // 本赛季最高得分

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId, category]) // 每个用户每个赛季每个类别只有一条记录
  @@index([userId])
  @@index([seasonId])
  @@index([category])
  @@index([rank])
  @@index([score(sort: Desc)])
  @@index([seasonId, category])
  @@index([seasonId, category, score(sort: Desc)])
  @@index([seasonId, category, rank])
  @@map("season_leaderboards")
}

// ==================== 赛季奖励系统 (Season Reward System) ====================

// 赛季奖励类型枚举
enum SeasonRewardType {
  TOKENS // 零芥子代币
  BADGE // 徽章
  TITLE // 称号
  AVATAR_FRAME // 头像框
}

// 用户赛季奖励状态枚举
enum UserSeasonRewardStatus {
  PENDING // 待领取
  CLAIMED // 已领取
  EXPIRED // 已过期
}

// 赛季奖励定义模型 - 存储每个段位的奖励配置
model SeasonReward {
  id          String           @id @default(uuid())
  seasonId    String           @map("season_id")
  tier        SeasonTier // 对应的段位
  rewardType  SeasonRewardType @map("reward_type") // 奖励类型
  rewardValue Json             @map("reward_value") // 奖励详情（JSON格式：{amount: 100} 或 {badgeId: "xxx", titleId: "xxx", frameId: "xxx"}）
  description String? // 奖励描述
  sortOrder   Int              @default(0) @map("sort_order") // 排序顺序（同一段位可能有多个奖励）
  createdAt   DateTime         @default(now()) @map("created_at")

  // Relations
  season           Season             @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  userSeasonReward UserSeasonReward[]

  @@index([seasonId])
  @@index([tier])
  @@index([seasonId, tier])
  @@index([sortOrder])
  @@map("season_rewards")
}

// 用户赛季奖励记录模型 - 存储用户领取的赛季奖励
model UserSeasonReward {
  id        String                 @id @default(uuid())
  userId    String                 @map("user_id")
  seasonId  String                 @map("season_id")
  rewardId  String                 @map("reward_id")
  status    UserSeasonRewardStatus @default(PENDING) // 奖励状态
  claimedAt DateTime?              @map("claimed_at") // 领取时间
  expiresAt DateTime?              @map("expires_at") // 过期时间（可选）
  createdAt DateTime               @default(now()) @map("created_at")
  updatedAt DateTime               @updatedAt @map("updated_at")

  // Relations
  reward       Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonReward SeasonReward @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@unique([userId, rewardId]) // 每个用户对每个奖励只有一条记录
  @@index([userId])
  @@index([seasonId])
  @@index([rewardId])
  @@index([status])
  @@index([userId, seasonId])
  @@index([userId, status])
  @@map("user_season_rewards")
}

// ==================== 限时活动系统 (Limited-Time Event System) ====================
// 需求26: 限时活动系统 - 与社区活动系统(Activity)不同，这是管理员创建的时间限定活动

// 限时活动类型枚举
enum LimitedEventType {
  FESTIVAL // 节日活动（春节、中秋、圣诞等）
  ANNIVERSARY // 周年庆活动
  THEME // 主题活动（特定主题的限时活动）
  FLASH // 闪电活动（短期高强度活动）
}

// 限时活动状态枚举
enum LimitedEventStatus {
  UPCOMING // 即将开始
  ACTIVE // 进行中
  ENDED // 已结束
}

// 限时活动任务类型枚举
enum LimitedEventTaskType {
  READ_CHAPTERS // 阅读章节
  CREATE_CONTENT // 创作内容（发布章节/作品）
  SOCIAL_INTERACTION // 社交互动（点赞/评论/引用）
  DAILY_LOGIN // 每日登录
  SHARE_CONTENT // 分享内容
  COLLECT_ITEMS // 收集道具（活动专属）
  COMPLETE_ACHIEVEMENT // 完成成就
  TIP_CREATORS // 打赏创作者
  INVITE_FRIENDS // 邀请好友
  CUSTOM // 自定义任务
}

// 限时活动奖励类型枚举
enum LimitedEventRewardType {
  TOKENS // 零芥子代币
  BADGE // 徽章
  TITLE // 称号
  AVATAR_FRAME // 头像框
  THEME // 主题皮肤
  EXPERIENCE // 经验值
  EXCLUSIVE_ITEM // 活动专属道具
}

// 限时活动模型 - 主活动定义
model LimitedEvent {
  id            String             @id @default(uuid())
  name          String             @db.VarChar(50) // 活动名称
  description   String?            @db.VarChar(1000) // 活动描述
  coverImageUrl String?            @map("cover_image_url") // 活动封面图URL
  eventType     LimitedEventType   @map("event_type") // 活动类型
  status        LimitedEventStatus @default(UPCOMING) // 活动状态
  startDate     DateTime           @map("start_date") // 开始日期
  endDate       DateTime           @map("end_date") // 结束日期
  isPublished   Boolean            @default(false) @map("is_published") // 是否已发布
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  // Relations
  tasks                 LimitedEventTask[]
  milestones            LimitedEventMilestone[]
  userParticipations    LimitedEventParticipation[]
  userTaskProgress      LimitedEventUserTaskProgress[]
  userMilestoneProgress LimitedEventUserMilestoneProgress[]

  @@index([eventType])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([isPublished])
  @@index([status, isPublished])
  @@map("limited_events")
}

// 限时活动任务模型 - 活动内的任务定义
model LimitedEventTask {
  id          String                 @id @default(uuid())
  eventId     String                 @map("event_id")
  name        String                 @db.VarChar(100) // 任务名称
  description String?                @db.VarChar(500) // 任务描述
  taskType    LimitedEventTaskType   @map("task_type") // 任务类型
  targetValue Int                    @map("target_value") // 目标值（如阅读10章节）
  rewardType  LimitedEventRewardType @map("reward_type") // 奖励类型
  rewardValue Json                   @map("reward_value") // 奖励详情（JSON格式：{amount: 100} 或 {badgeId: "xxx"}）
  sortOrder   Int                    @default(0) @map("sort_order") // 排序顺序
  isRequired  Boolean                @default(false) @map("is_required") // 是否必须完成
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")

  // Relations
  event        LimitedEvent                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userProgress LimitedEventUserTaskProgress[]

  @@index([eventId])
  @@index([taskType])
  @@index([sortOrder])
  @@index([eventId, sortOrder])
  @@map("limited_event_tasks")
}

// 限时活动里程碑模型 - 活动里程碑奖励定义
model LimitedEventMilestone {
  id               String                 @id @default(uuid())
  eventId          String                 @map("event_id")
  name             String                 @db.VarChar(100) // 里程碑名称
  description      String?                @db.VarChar(500) // 里程碑描述
  requiredProgress Int                    @map("required_progress") // 需要完成的任务数量
  rewardType       LimitedEventRewardType @map("reward_type") // 奖励类型
  rewardValue      Json                   @map("reward_value") // 奖励详情（JSON格式）
  sortOrder        Int                    @default(0) @map("sort_order") // 排序顺序
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")

  // Relations
  event        LimitedEvent                        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userProgress LimitedEventUserMilestoneProgress[]

  @@index([eventId])
  @@index([sortOrder])
  @@index([eventId, sortOrder])
  @@map("limited_event_milestones")
}

// 用户限时活动参与记录模型 - 记录用户参与活动的状态
model LimitedEventParticipation {
  id                 String    @id @default(uuid())
  userId             String    @map("user_id")
  eventId            String    @map("event_id")
  joinedAt           DateTime  @default(now()) @map("joined_at") // 参与时间
  completedTaskCount Int       @default(0) @map("completed_task_count") // 已完成任务数
  lastActivityAt     DateTime? @map("last_activity_at") // 最后活动时间
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  // Relations
  event LimitedEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId]) // 每个用户每个活动只有一条参与记录
  @@index([userId])
  @@index([eventId])
  @@index([userId, eventId])
  @@map("limited_event_participations")
}

// 用户限时活动任务进度模型 - 记录用户的任务完成进度
model LimitedEventUserTaskProgress {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  eventId         String    @map("event_id")
  taskId          String    @map("task_id")
  currentProgress Int       @default(0) @map("current_progress") // 当前进度
  isCompleted     Boolean   @default(false) @map("is_completed") // 是否已完成
  completedAt     DateTime? @map("completed_at") // 完成时间
  isClaimed       Boolean   @default(false) @map("is_claimed") // 是否已领取奖励
  claimedAt       DateTime? @map("claimed_at") // 领取时间
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  event LimitedEvent     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  task  LimitedEventTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId]) // 每个用户每个任务只有一条进度记录
  @@index([userId])
  @@index([eventId])
  @@index([taskId])
  @@index([userId, eventId])
  @@index([isCompleted])
  @@index([isClaimed])
  @@map("limited_event_user_task_progress")
}

// 用户限时活动里程碑进度模型 - 记录用户的里程碑完成状态
model LimitedEventUserMilestoneProgress {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  eventId     String    @map("event_id")
  milestoneId String    @map("milestone_id")
  isUnlocked  Boolean   @default(false) @map("is_unlocked") // 是否已解锁
  unlockedAt  DateTime? @map("unlocked_at") // 解锁时间
  isClaimed   Boolean   @default(false) @map("is_claimed") // 是否已领取奖励
  claimedAt   DateTime? @map("claimed_at") // 领取时间
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  event     LimitedEvent          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  milestone LimitedEventMilestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@unique([userId, milestoneId]) // 每个用户每个里程碑只有一条进度记录
  @@index([userId])
  @@index([eventId])
  @@index([milestoneId])
  @@index([userId, eventId])
  @@index([isUnlocked])
  @@index([isClaimed])
  @@map("limited_event_user_milestone_progress")
}

// ==================== 小说库分支系统 (Library Branch System) ====================

// 小说库类型
enum LibraryType {
  ORIGINAL // 原创库 - 仅库拥有者可发布正文主线
  SHARED // 共享库 - 所有用户可上传分支
}

// 分支类型
enum BranchType {
  MAIN // 正文分支 - 原创内容或续写
  DERIVATIVE // 改写分支 - 同人/IF线/改编
  MANGA // 漫画分支 - 漫画改编版本
}

// 改写子类型
enum DerivativeType {
  FANFIC // 同人
  IF_LINE // IF线
  ADAPTATION // 改编
}

// 上传费用类型
enum UploadFeeType {
  PER_THOUSAND_WORDS // 按千字计费
  PER_PAGE // 按页数计费（漫画用）
}

// 修订建议类型
enum SuggestionType {
  MODIFY // 修改段落内容
  INSERT_BEFORE // 在段落前插入
  INSERT_AFTER // 在段落后插入
  ADD_IMAGE // 添加插图
}

// 修订建议状态
enum SuggestionStatus {
  PENDING // 待审核
  ACCEPTED // 已采纳
  REJECTED // 已拒绝
}

// 分支交易类型
enum BranchTransactionType {
  UPLOAD_FEE // 上传费用
  TIP // 打赏
}

// 小说库模型
model Library {
  id          String      @id @default(uuid())
  ownerId     String      @map("owner_id")
  workId      String      @unique @map("work_id") // 关联原始作品
  title       String
  description String?
  coverImage  String?     @map("cover_image")
  libraryType LibraryType @default(ORIGINAL) @map("library_type")

  // 收益设置
  ownerCutPercent Int           @default(0) @map("owner_cut_percent") // 0-30%
  uploadFeeType   UploadFeeType @default(PER_THOUSAND_WORDS) @map("upload_fee_type")
  uploadFeeRate   Int           @default(0) @map("upload_fee_rate") // 费率（分/千字 或 分/页）

  // 统计
  hotScore       Float @default(0) @map("hot_score")
  branchCount    Int   @default(0) @map("branch_count")
  totalTipAmount Int   @default(0) @map("total_tip_amount")

  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  owner    User            @relation(fields: [ownerId], references: [id])
  work     Work            @relation(fields: [workId], references: [id])
  branches LibraryBranch[]

  @@index([ownerId])
  @@index([libraryType])
  @@index([hotScore(sort: Desc)])
  @@index([createdAt])
  @@map("libraries")
}

// 小说库分支模型
model LibraryBranch {
  id        String @id @default(uuid())
  libraryId String @map("library_id")
  creatorId String @map("creator_id")
  workId    String @unique @map("work_id") // 分支内容作为独立作品存储

  branchType     BranchType      @map("branch_type")
  derivativeType DerivativeType? @map("derivative_type") // 仅 DERIVATIVE 类型使用

  // 分支点
  forkFromChapterId   String? @map("fork_from_chapter_id")
  forkFromParagraphId String? @map("fork_from_paragraph_id")

  // 统计
  likeCount Int   @default(0) @map("like_count")
  tipAmount Int   @default(0) @map("tip_amount")
  viewCount Int   @default(0) @map("view_count")
  hotScore  Float @default(0) @map("hot_score")

  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  library           Library    @relation(fields: [libraryId], references: [id])
  creator           User       @relation(fields: [creatorId], references: [id])
  work              Work       @relation(fields: [workId], references: [id])
  forkFromChapter   Chapter?   @relation("ForkFromChapter", fields: [forkFromChapterId], references: [id])
  forkFromParagraph Paragraph? @relation("ForkFromParagraph", fields: [forkFromParagraphId], references: [id])

  suggestions  ContentSuggestion[]
  transactions BranchTransaction[]

  @@index([libraryId])
  @@index([creatorId])
  @@index([branchType])
  @@index([hotScore(sort: Desc)])
  @@index([libraryId, branchType])
  @@map("library_branches")
}

// 修订建议模型
model ContentSuggestion {
  id          String @id @default(uuid())
  branchId    String @map("branch_id")
  paragraphId String @map("paragraph_id")
  suggesterId String @map("suggester_id")

  suggestionType SuggestionType   @map("suggestion_type")
  status         SuggestionStatus @default(PENDING)

  // 建议内容
  suggestedContent String? @map("suggested_content")
  imageUrl         String? @map("image_url") // ADD_IMAGE 类型使用

  // 奖励
  rewardAmount Int @default(0) @map("reward_amount")

  // 审核信息
  reviewedAt DateTime? @map("reviewed_at")
  reviewNote String?   @map("review_note")

  // 采纳后生成的卡片
  cardId String? @unique @map("card_id")

  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  branch    LibraryBranch @relation(fields: [branchId], references: [id])
  paragraph Paragraph     @relation(fields: [paragraphId], references: [id])
  suggester User          @relation(fields: [suggesterId], references: [id])
  card      Card?         @relation(fields: [cardId], references: [id])

  @@index([branchId])
  @@index([paragraphId])
  @@index([suggesterId])
  @@index([status])
  @@index([branchId, status])
  @@map("content_suggestions")
}

// 分支交易模型
model BranchTransaction {
  id              String                @id @default(uuid())
  branchId        String                @map("branch_id")
  userId          String                @map("user_id") // 交易发起者
  transactionType BranchTransactionType @map("transaction_type")

  // 金额明细
  totalAmount    Int @map("total_amount")
  platformAmount Int @map("platform_amount") // 平台收入
  ownerAmount    Int @map("owner_amount") // 库拥有者收入
  creatorAmount  Int @map("creator_amount") // 分支创作者收入

  // 关联的钱包交易ID
  platformTransactionId String? @map("platform_transaction_id")
  ownerTransactionId    String? @map("owner_transaction_id")
  creatorTransactionId  String? @map("creator_transaction_id")
  userTransactionId     String? @map("user_transaction_id") // 用户支出交易

  message   String? // 打赏留言
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  branch LibraryBranch @relation(fields: [branchId], references: [id])
  user   User          @relation(fields: [userId], references: [id])

  @@index([branchId])
  @@index([userId])
  @@index([transactionType])
  @@index([createdAt])
  @@map("branch_transactions")
}
